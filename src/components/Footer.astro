---
/**
 * @components/Footer.astro
 * フッターを定義するコンポーネント
 * @param locale ロケール
 * @param localeBaseUrl ロケールベースURL
 */
import { t, type Locale } from '@i18n/i18n.config';

interface Props {
    locale: Locale;
    localeBaseUrl: string;
}

const { locale, localeBaseUrl } = Astro.props;

// サイト開始年
const startyear = 2026;
// 現在の年
const year = new Date().getFullYear();
---
<footer class="site-footer">
    <div class="site-footer-links">
        <a href={`${localeBaseUrl}/privacy`}>{t('footer.privacy', locale)}</a>
        <a href={`${localeBaseUrl}/terms`}>{t('footer.terms', locale)}</a>
    </div>
    <div class="site-footer-credit">
        © {startyear}-{year} {t('site.title', locale)}.
    </div>
</footer>