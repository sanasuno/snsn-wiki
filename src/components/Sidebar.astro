---
/**
 * @components/Sidebar.astro
 * サイト全体のサイドバーを定義するコンポーネント
 * @layout/sidebar.config.ts からナビゲーションを読み込み表示する
 * @param {Object} props
 * @param {Locale} props.locale - ロケール
 * @param {string} props.nPrefixBaseUrl - プレフィックスベースURL
 * @param {string} props.currentPath - 現在のパス
 */
import { getCollection } from "astro:content";
import { t, defaultLocale, type Locale } from "@i18n/i18n.config";
import { sidebarNavigation, autoAddUnknownCategories } from "@layouts/sidebar.config";
import { normalize } from "@scripts/utils";

interface Props { 
    locale: Locale;
    nPrefixBaseUrl: string;
    currentPath: string;
}

const { nPrefixBaseUrl, locale, currentPath } = Astro.props;

// 現在のパスが指定されたパスと一致するかチェック
function isCurrentPath(path: string): boolean {
    const route = normalize(path);
    return currentPath === route;
}
// 現在のページIDが指定されたページIDと一致するかチェック
function isCurrentPageId(pageId: string): boolean {
    return isCurrentPath(getRoute(pageId));
}

// スラッグからルートを取得する関数
function getBaseSlug(pageId: string): string {
    return pageId.includes('/') ? pageId.split('/').slice(1).join('/') : pageId;
}
function getRoute(pageId: string): string {
    const baseSlug = getBaseSlug(pageId);
    return `${nPrefixBaseUrl}/${baseSlug}`.replace(/\/+/g, '/');
}

// 全ページを取得
const allPages = await getCollection("wiki", (p) => !p.data.draft && !p.data.hidden);

// 重複を排除して最も適切なページを選択
const uniquePagesByBaseSlug: Record<string, typeof allPages[0]> = {};
for (const page of allPages) {
    const parts = page.id.split('/');
    const hasLocale = parts.length > 1;
    const pLocale = 
        hasLocale 
            ? parts[0] 
            : defaultLocale;
    const pBaseSlug = getBaseSlug(page.id);
    const existing = uniquePagesByBaseSlug[pBaseSlug];
    
    if (!existing) {
        uniquePagesByBaseSlug[pBaseSlug] = page;
    } else if (pLocale === locale) {
        uniquePagesByBaseSlug[pBaseSlug] = page;
    } else if (
        pLocale === defaultLocale && 
        existing.id.split('/')[0] !== locale
    ) {
        uniquePagesByBaseSlug[pBaseSlug] = page;
    }
}


// カテゴリ別にページをグループ化
const pages = Object.values(uniquePagesByBaseSlug);
const byCategory: Record<string, typeof pages> = {};
for (const page of pages) {
    const category: string = page.data.category || '';
    if (!byCategory[category]) {
        byCategory[category] = [];
    }
    byCategory[category].push(page);
}


// スラッグからページをマッピング
const slugMap: Record<string, (typeof pages)[0]> = {};
for (const page of pages) {
    const baseSlug = getBaseSlug(page.id);
    slugMap[baseSlug] = page;
}

const renderedCategories = new Set<string>();

---

<aside class="sidebar" id="sidebar">
    <nav aria-label={t("sidebar.navigation", locale)}>
        {sidebarNavigation.map(section => {
            const defaultCollapsed = section.collapsed ?? false;
            const sectionTitle = t(section.title, locale);
            const storageKey = `snsn-sidebar-${section.title}`;

            if (section.category && !section.items) {
                // カテゴリ指定あり、アイテム指定なしの場合
                const sectionCategory = t(section.category, locale);

                // 合致するカテゴリのページを収集
                const categoryPages = byCategory[sectionCategory] || [];
                if (categoryPages.length === 0) {
                    return null;
                }
                renderedCategories.add(sectionCategory);
                
                // ソート
                const sorted = [...categoryPages].sort((a, b) => {
                    if (section.autoSort === "order") {
                        return (a.data.order ?? 0) - (b.data.order ?? 0);
                    } else if (section.autoSort === "date") {
                        return (
                            (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
                        );
                    } else if (section.autoSort === "updated") {
                        return (
                            (b.data.updated?.getTime() ?? 0) - (a.data.updated?.getTime() ?? 0)
                        );
                    }
                    return a.data.title.localeCompare(b.data.title);
                });

                // レンダリング
                return (
                    <section class="sidebar-section">
                        <button class="sidebar-section-title sidebar-toggle" data-storage-key={storageKey} aria-expanded={defaultCollapsed ? "false" : "true"}>
                            {sectionTitle && <i class={`${section.icon} fa-fw`} />}
                            {sectionTitle}
                            <i class="fa-solid fa-chevron-down sidebar-chevron" />
                        </button>
                        <div class={`sidebar-nav sidebar-collapsible${defaultCollapsed ? ' collapsed' : ''}`}>
                            {
                                sorted.map(page => {
                                    return (
                                        <a href={getRoute(page.id)} class={isCurrentPageId(page.id) ? 'current' : ''}>
                                            <i class="fa-regular fa-file-lines fa-fw" />
                                            {page.data.title}
                                        </a>
                                    )
                                })
                            }
                        </div>
                    </section>
                );
            }

            if (section.items) {
                // アイテム指定ありの場合
                return (
                    <section class="sidebar-section">
                        <button class="sidebar-section-title sidebar-toggle" data-storage-key={storageKey} aria-expanded={defaultCollapsed ? "false" : "true"}>
                            {sectionTitle && <i class={`${section.icon} fa-fw`} />}
                            {sectionTitle}
                            <i class="fa-solid fa-chevron-down sidebar-chevron" />
                        </button>
                        <div class={`sidebar-nav sidebar-collapsible${defaultCollapsed ? ' collapsed' : ''}`}>
                            {section.items.map(item => {
                                let href = item.href;
                                let label = t(item.label || '', locale);
                                if (item.slug) {
                                    // item.slug から先頭のロケールを除いたパスを取得する
                                    const rawBaseSlug = 
                                        item.slug.startsWith(`/${locale}/`) 
                                            ? item.slug.slice(locale.length + 2) 
                                            : item.slug;
                                    const page = slugMap[rawBaseSlug];
                                    if (page) {
                                        href = getRoute(page.id);
                                        if (!item.label) {
                                            label = page.data.title;
                                        }
                                    }
                                } else if (href && !/^(https?:\/\/|mailto:|tel:|#)/.test(href)) {
                                    // 相対パスの場合
                                    href = 
                                        href === '/' 
                                            ? (nPrefixBaseUrl || '/') 
                                            : `${nPrefixBaseUrl}${href}`;
                                }
                                if (!href || !label) {
                                    // href または label が不足している場合はスキップ
                                    return null;
                                }
                                return ( 
                                    <a href={href} class={isCurrentPath(href) ? 'current' : ''} target={item.external ? '_blank' : null} rel={item.external ? 'noopener noreferrer' : null}>
                                        {item.icon 
                                            ? <i class={`${item.icon} fa-fw`} /> 
                                            : <i class="fa-regular fa-file-lines fa-fw" />}
                                        {' '}
                                        {label}
                                    </a>
                                );
                            })}
                        </div>
                    </section>
                );
            }
            return null;
        })}

        <!-- 未知のカテゴリを自動追加 -->
        {autoAddUnknownCategories && Object.entries(byCategory).map(([category, categoryPages]) => {
            if (renderedCategories.has(category)) {
                // すでにレンダリングされたカテゴリはスキップ
                return null;
            }
            const storageKey = `snsn-sidebar-${category}`;
            const sorted = [...categoryPages].sort(
                (a, b) => a.data.title.localeCompare(b.data.title)
            );
            return (
                <section class="sidebar-section">
                    <button class="sidebar-section-title sidebar-toggle" data-storage-key={storageKey} aria-expanded="true">
                        <i class="fa-solid fa-folder fa-fw" />
                        {t(category, locale)}
                        <i class="fa-solid fa-chevron-down sidebar-chevron" />
                    </button>
                    <div class="sidebar-nav sidebar-collapsible">
                        {sorted.map((page) => {
                            return (
                                <a href={getRoute(page.id)} class={isCurrentPageId(page.id) ? 'current' : ''}>
                                    <i class="fa-regular fa-file-lines fa-fw" />
                                    {page.data.title}
                                </a>
                            )
                        })}
                    </div>
                </section>
            )
        })}
    </nav>
</aside>
<script>
import { getPreference, savePreference } from "@scripts/storage";

    document.querySelectorAll<HTMLButtonElement>('.sidebar-toggle').forEach(button => {
        // data-storage-key 属性からキーを取得
        const key = button.dataset.storageKey;
        if (!key) return;
        const nav = button.nextElementSibling as HTMLElement | null;
        if (!nav) return;

        // ローカルストレージから保存された状態を読み込み
        const saved  = getPreference(key);
        if (saved !== null) {
            const isCollapsed = saved === 'true';
            button.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
            nav.classList.toggle('collapsed', isCollapsed);
        }

        // クリック時に状態を切り替えてローカルストレージに保存
        button.addEventListener('click', () => {
            const isExpanded = 
                button.getAttribute('aria-expanded') === 'true';
            const nextCollapsed = isExpanded;
            button.setAttribute('aria-expanded', nextCollapsed ? 'false' : 'true');
            nav.classList.toggle('collapsed', nextCollapsed);
            savePreference(key, nextCollapsed ? 'true' : 'false');
        });
    });
</script>
        