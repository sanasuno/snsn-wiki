---
/**
 * @layouts/MainLayout.astro
 * サイト全体のレイアウトを定義するファイル
 */
import { t, defaultLocale, type Locale } from '@i18n/i18n.config';
import Header from '@components/Header.astro';
import Sidebar from '@components/Sidebar.astro';
import MainContent from '@components/MainContent.astro';
import Toc from '@components/Toc.astro';

import '@styles/global.css';
import '@styles/theme.css';
import { normalize } from '@scripts/utils';

interface Props {
    title: string;
    description?: string;
    locale?: Locale;
    alternateLinks?: { locale: Locale; url: string }[];
    headings?: { depth: number; slug: string; text: string }[];
    tags?: string[];
    date?: Date;
    updated?: Date;
}

const {
    title,
    description,
    locale = defaultLocale,
    alternateLinks = [],
    headings = [],
    tags = [],
    date,
    updated,
}: Props = Astro.props;

// 基本URL設定
const currentPath = normalize(Astro.url.pathname) || '/';
const baseUrl = normalize(import.meta.env.BASE_URL);
const nPrefixBaseUrl = normalize(`${baseUrl}/${locale}`);
const canonicalUrl = new URL(currentPath, Astro.site);


// 目次パネルの表示判定
// - 見出しがある場合に表示
const hasTocPanel = headings.length > 0;

// OGPでの表示名と説明文
const siteTitle = t('site.title', locale) ?? t('site.title', defaultLocale);
const siteDescription = t('site.description', locale) ?? t('site.description', defaultLocale);
---
<!DOCTYPE html>
<html lang={locale} data-lang={locale} data-default-locale={defaultLocale}>
    <head prefix="og: http://ogp.me/ns#">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{title} | {siteTitle}</title>
        <meta name="description" content={description ?? siteDescription} />
        <meta name="generator" content="snsn-wiki" />
        <link rel="icon" href={`${baseUrl}/favicon.ico`} sizes="48x48" />
        <link rel="icon" href={`${baseUrl}/favicon.svg`} type="image/svg+xml" />
        <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
        <link rel="canonical" href={canonicalUrl.href} />
        {
            alternateLinks.map((link) => (
                <link rel="alternate" href={link.url} hreflang={link.locale} />
            ))
        }
        <!-- OGP -->
        <meta property="og:title" content={`${title} | ${siteTitle}`} />
        <meta property="og:description" content={description ?? siteDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl.href} />
        <meta property="og:image" content={new URL(`${baseUrl}/ogp.png`, Astro.site).href} />
        <meta property="og:site_name" content={siteTitle} />
        <meta property="og:locale" content={t('og.locale', locale)} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={`${title} | ${siteTitle}`} />
        <meta name="twitter:description" content={description ?? siteDescription} />
        <meta name="twitter:image" content={new URL(`${baseUrl}/ogp.png`, Astro.site).href} />
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" />
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Noto+Sans+JP:wght@100..900&family=Noto+Serif+JP:wght@200..900&display=swap" rel="stylesheet">
        <!-- テーマ初期化 -->
        <script is:inline>
            (function() {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark' || savedTheme === 'light') {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                } else if (!savedTheme) {
                    // テーマ未設定の場合はOSの設定を優先
                    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
                }
            })();
        </script>
        <!-- 言語選択初期化 -->
        <script>
            import { initI18n } from '@scripts/i18n';
            initI18n();
        </script>
    </head>
    <body>
        <div class={`layout${hasTocPanel ? '' : ' no-toc'}`}>
            <!-- ヘッダー -->
            <Header 
                locale={locale} 
                nPrefixBaseUrl={nPrefixBaseUrl} 
                currentPath={currentPath}
            />

            <!-- サイドバー -->
            <Sidebar 
                locale={locale} 
                nPrefixBaseUrl={nPrefixBaseUrl} 
                currentPath={currentPath}
            />

            <!-- メインコンテンツ -->
            <MainContent 
                title={title} 
                locale={locale}
                nPrefixBaseUrl={nPrefixBaseUrl} 
                currentPath={currentPath}
                tags={tags}
                date={date}
                updated={updated}
            >
                <slot />
            </MainContent>

            <!-- 目次パネル -->
            {hasTocPanel && <Toc />}
        </div>
        <script>
            import "@scripts/main"
        </script>
    </body>
</html>