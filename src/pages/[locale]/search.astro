---
/**
 * src/pages/[locale]/search.astro
 *
 * 全文検索ページ。
 * - ?q= パラメータによる URL 共有対応
 * - ビルド時生成の /search-index.[locale].json をクライアントサイドで fetch
 * - リアルタイムフィルタリング（デバウンス 150ms）
 */
import { locales, defaultLocale, type Locale } from '@i18n/i18n.config';
import { t } from '@i18n/i18n.config';
import MainLayout from '@layouts/MainLayout.astro';
import { removeTrailingSlash } from '@scripts/utils';
import type { GetStaticPathsResult } from 'astro';

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
    return locales.map((locale) => ({ params: { locale } }));
}

interface Props {
    locale: Locale;
}

const { locale } = Astro.params as { locale: Locale };
const baseUrl = removeTrailingSlash(import.meta.env.BASE_URL);

// i18n ラベル（キー未定義時はフォールバック）
const label = {
    pageTitle:   t('search.title',       locale) ?? (locale === 'ja' ? '検索'                        : 'Search'),
    placeholder: t('search.placeholder', locale) ?? (locale === 'ja' ? 'ページを検索…'               : 'Search pages…'),
    noResults:   t('search.noResults',   locale) ?? (locale === 'ja' ? '結果が見つかりませんでした'   : 'No results found'),
    loading:     t('search.loading',     locale) ?? (locale === 'ja' ? '読み込み中…'                 : 'Loading…'),
    resultCount: (n: number) => locale === 'ja' ? `${n} 件` : `${n} result${n !== 1 ? 's' : ''}`,
    description: locale === 'ja'
        ? 'Wikiページのタイトルと本文を検索します'
        : 'Search across all wiki page titles and content',
};

// alternate links（言語切替用）
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const alternateLinks = locales.map((l) => ({
    locale: l,
    url: `${siteUrl}${baseUrl}/${l}/search`,
}));
---

<MainLayout
    title={label.pageTitle}
    description={label.description}
    locale={locale}
    alternateLinks={alternateLinks}
    isWikiPage={false}
    showMeta={false}
>
    <div class="search-page">
        <!-- ページヘッダー -->
        <div class="specialpage-title">
            <h1>
                <i class="fa-solid fa-magnifying-glass" style="color: var(--color-accent); margin-right: 0.4em;"></i>
                {label.pageTitle}
            </h1>
            <p class="specialpage-description">{label.description}</p>
        </div>

        <!-- 検索入力 -->
        <div class="sp-search-bar">
            <i class="fa-solid fa-magnifying-glass sp-search-icon"></i>
            <input
                id="sp-input"
                class="sp-search-input"
                type="search"
                placeholder={label.placeholder}
                autocomplete="off"
                spellcheck="false"
                autofocus
            />
            <button id="sp-clear" class="sp-clear-btn" aria-label="clear" hidden>
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- ステータスバー -->
        <p id="sp-status" class="sp-status" aria-live="polite" hidden></p>

        <!-- 結果リスト -->
        <ul id="sp-results" class="sp-results" role="list"></ul>
    </div>
</MainLayout>

<style>
/* -------- ページ全体 -------- */
.search-page {
    max-width: 760px;
}

/* -------- 検索バー -------- */
.sp-search-bar {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 20px;
}

.sp-search-icon {
    position: absolute;
    left: 14px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    pointer-events: none;
}

.sp-search-input {
    width: 100%;
    padding: 12px 44px 12px 40px;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg, 10px);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
}

.sp-search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-light, rgba(99,102,241,0.12));
}

.sp-search-input::-webkit-search-cancel-button {
    display: none;
}

.sp-clear-btn {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    padding: 4px 6px;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition);
    display: flex;
    align-items: center;
}

.sp-clear-btn:hover {
    background: var(--color-bg-hover);
    color: var(--color-text);
}

/* -------- ステータス -------- */
.sp-status {
    font-size: 0.825rem;
    color: var(--color-text-muted);
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 6px;
}

/* -------- 結果リスト -------- */
.sp-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

/* -------- 各結果カード -------- */
.sp-result-item a {
    display: block;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background var(--transition), transform var(--transition);
}

.sp-result-item a:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-accent);
    transform: translateX(2px);
}

.sp-result-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 5px;
    display: flex;
    align-items: center;
    gap: 7px;
}

.sp-result-title i {
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    flex-shrink: 0;
}

.sp-result-title mark,
.sp-result-excerpt mark {
    background: var(--color-accent-light, rgba(99,102,241,0.15));
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: 700;
}

.sp-result-excerpt {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.sp-result-url {
    margin-top: 5px;
    font-size: 0.7rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
}

/* -------- 空状態 -------- */
.sp-empty {
    padding: 48px 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.sp-empty i {
    font-size: 2rem;
    color: var(--color-text-subtle);
}

/* -------- ローディング -------- */
.sp-loading {
    padding: 48px 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
}
</style>

<script define:vars={{ locale, baseUrl }}>
// ----------------------------------------
// 設定
// ----------------------------------------
const DEBOUNCE_MS   = 150;
const MAX_RESULTS   = 50;
const CONTEXT_CHARS = 80;

// ----------------------------------------
// DOM
// ----------------------------------------
const input    = document.getElementById('sp-input');
const results  = document.getElementById('sp-results');
const statusEl = document.getElementById('sp-status');
const clearBtn = document.getElementById('sp-clear');

let index        = null;   // SearchEntry[]
let debounceTimer = null;
let currentQuery  = '';

// ----------------------------------------
// URL パラメータとの同期
// ----------------------------------------

function getQueryParam() {
    return new URLSearchParams(window.location.search).get('q') ?? '';
}

function setQueryParam(q) {
    const url = new URL(window.location.href);
    if (q) {
        url.searchParams.set('q', q);
    } else {
        url.searchParams.delete('q');
    }
    // pushState で履歴に積む（戻るボタン対応）
    window.history.pushState({}, '', url.toString());
}

// ページロード時に ?q= があれば検索を実行
window.addEventListener('DOMContentLoaded', async () => {
    const q = getQueryParam();
    if (q) {
        input.value = q;
        clearBtn.hidden = false;
        await ensureIndex();
        runSearch(q);
    } else {
        showInitial();
    }
});

// 戻る/進む ボタン対応
window.addEventListener('popstate', () => {
    const q = getQueryParam();
    input.value = q;
    clearBtn.hidden = !q;
    if (q) {
        runSearch(q);
    } else {
        showInitial();
    }
});

// ----------------------------------------
// インデックスの遅延ロード
// ----------------------------------------

async function ensureIndex() {
    if (index) return;
    showLoading();
    try {
        const res = await fetch(`${baseUrl}/search-index.${locale}.json`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        index = await res.json();
    } catch (e) {
        console.error('[Search] index load failed:', e);
        showError();
    }
}

// ----------------------------------------
// 検索ロジック
// ----------------------------------------

function escapeRe(s) {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function highlight(text, query) {
    const safe = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    if (!query) return safe;
    const re = new RegExp(`(${escapeRe(query)})`, 'gi');
    return safe.replace(re, '<mark>$1</mark>');
}

function extractSnippet(body, query) {
    if (!query) return body.slice(0, 140);
    const lc  = body.toLowerCase();
    const pos = lc.indexOf(query.toLowerCase());
    if (pos === -1) return body.slice(0, 140);
    const start = Math.max(0, pos - CONTEXT_CHARS);
    const end   = Math.min(body.length, pos + query.length + CONTEXT_CHARS);
    let snippet = body.slice(start, end);
    if (start > 0) snippet = '…' + snippet;
    if (end < body.length) snippet += '…';
    return snippet;
}

function search(query) {
    const q = query.trim().toLowerCase();
    if (!q || !index) return [];

    const scored = [];
    for (const entry of index) {
        const inTitle = entry.title.toLowerCase().includes(q);
        const inBody  = entry.body.toLowerCase().includes(q);
        if (!inTitle && !inBody) continue;
        scored.push({ entry, score: (inTitle ? 2 : 0) + (inBody ? 1 : 0) });
    }

    scored.sort((a, b) => b.score - a.score);
    return scored.slice(0, MAX_RESULTS).map(s => s.entry);
}

// ----------------------------------------
// 描画
// ----------------------------------------

function renderResults(entries, query) {
    results.innerHTML = '';

    if (!entries.length) {
        showStatus('empty', query);
        return;
    }

    // 件数表示
    const count = entries.length;
    const countLabel = locale === 'ja'
        ? `${count} 件`
        : `${count} result${count !== 1 ? 's' : ''}`;
    showStatusText(`<i class="fa-solid fa-check" style="color:var(--color-accent)"></i> ${countLabel}`);

    for (const entry of entries) {
        const snippet = extractSnippet(entry.body, query.trim());
        const li = document.createElement('li');
        li.className = 'sp-result-item';

        const a = document.createElement('a');
        a.href = `${baseUrl}${entry.url}`;
        a.innerHTML = `
            <div class="sp-result-title">
                <i class="fa-regular fa-file-lines"></i>
                ${highlight(entry.title, query.trim())}
            </div>
            <div class="sp-result-excerpt">${highlight(snippet, query.trim())}</div>
            <div class="sp-result-url">${entry.url}</div>
        `;

        li.appendChild(a);
        results.appendChild(li);
    }
}

// ----------------------------------------
// 状態表示ヘルパー
// ----------------------------------------

function showStatusText(html) {
    statusEl.innerHTML = html;
    statusEl.hidden = false;
}

function showInitial() {
    results.innerHTML = '';
    statusEl.hidden = true;
}

function showLoading() {
    results.innerHTML = `
        <li class="sp-loading">
            <i class="fa-solid fa-spinner fa-spin" style="margin-right:8px"></i>
            ${locale === 'ja' ? '読み込み中…' : 'Loading…'}
        </li>`;
    statusEl.hidden = true;
}

function showError() {
    results.innerHTML = `
        <li class="sp-empty">
            <i class="fa-solid fa-circle-exclamation"></i>
            ${locale === 'ja'
                ? 'インデックスの読み込みに失敗しました'
                : 'Failed to load search index'}
        </li>`;
    statusEl.hidden = true;
}

function showStatus(type, query = '') {
    if (type === 'empty') {
        results.innerHTML = `
            <li class="sp-empty">
                <i class="fa-regular fa-face-frown-open"></i>
                ${locale === 'ja'
                    ? `"${query}" に一致するページが見つかりませんでした`
                    : `No results found for "${query}"`}
            </li>`;
        statusEl.hidden = true;
    }
}

// ----------------------------------------
// 検索実行
// ----------------------------------------

async function runSearch(query) {
    currentQuery = query;
    await ensureIndex();
    if (!index) return;
    const hits = search(query);
    renderResults(hits, query);
}

// ----------------------------------------
// イベント
// ----------------------------------------

input?.addEventListener('input', () => {
    const q = input.value;
    clearBtn.hidden = !q;

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        setQueryParam(q);
        if (!q.trim()) {
            showInitial();
            return;
        }
        runSearch(q);
    }, DEBOUNCE_MS);
});

clearBtn?.addEventListener('click', () => {
    input.value = '';
    clearBtn.hidden = true;
    setQueryParam('');
    showInitial();
    input.focus();
});

// ----------------------------------------
// キーボード: Ctrl+K / / でこのページの入力欄にフォーカス
// ----------------------------------------
document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        input?.focus();
    }
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
        e.preventDefault();
        input?.focus();
    }
});
</script>